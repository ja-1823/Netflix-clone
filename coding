<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Netflix Clone</title>

<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:Arial, sans-serif;
}

body{
    background:black;
    color:white;
}

/* Header */
header{
    display:flex;
    justify-content:space-between;
    align-items:center;
    padding:20px 50px;
    position:absolute;
    width:100%;
}

.logo{
    color:red;
    font-size:40px;
    font-weight:bold;
}

.signin{
    background:red;
    color:white;
    border:none;
    padding:10px 20px;
    border-radius:5px;
    cursor:pointer;
}

/* Hero Section */
.hero{
    height:100vh;
    background:url('https://images.unsplash.com/photo-1489599849927-2ee91cede3ba?w=1600')
    center/cover no-repeat;
    display:flex;
    justify-content:center;
    align-items:center;
    text-align:center;
}

.overlay{
    background:rgba(0,0,0,0.7);
    width:100%;
    height:100%;
    display:flex;
    flex-direction:column;
    justify-content:center;
    align-items:center;
    padding:20px;
}

.hero h1{
    font-size:60px;
    margin-bottom:20px;
}

.hero p{
    font-size:24px;
    margin-bottom:20px;
}

.email-box{
    display:flex;
    gap:10px;
    flex-wrap:wrap;
    justify-content:center;
}

.email-box input{
    padding:15px;
    width:300px;
    border:none;
}

.email-box button{
    background:red;
    color:white;
    border:none;
    padding:15px 25px;
    font-size:18px;
    cursor:pointer;
}

/* Movies Section */
.movies{
    padding:50px;
}

.movies h2{
    margin-bottom:20px;
}

.movie-row{
    display:flex;
    gap:15px;
    flex-wrap:wrap;
}

.movie{
    width:220px;
    height:320px;
    background:#222;
    border-radius:10px;
    display:flex;
    justify-content:center;
    align-items:center;
    transition:0.3s;
    cursor:pointer;
}

.movie:hover{
    transform:scale(1.08);
}

/* Features */
.features{
    padding:50px;
    text-align:center;
}

.features h2{
    margin-bottom:20px;
}

.feature-box{
    background:#111;
    margin:15px auto;
    max-width:700px;
    padding:20px;
    border-radius:10px;
}

/* Footer */
footer{
    text-align:center;
    padding:30px;
    background:#111;
    color:gray;
}

/* Mobile */
@media(max-width:768px){

.hero h1{
    font-size:35px;
}

.hero p{
    font-size:18px;
}

header{
    padding:20px;
}

.logo{
    font-size:28px;
}

.movie{
    width:160px;
    height:220px;
}
}
</style>

</head>
<body>

<header>
    <div class="logo">NETFLIX</div>
    <button class="signin">Sign In</button>
</header>

<section class="hero">
    <div class="overlay">
        <h1>Unlimited Movies, TV Shows and More</h1>
        <p>Watch anywhere. Cancel anytime.</p>

        <div class="email-box">
            <input type="email" placeholder="Email Address">
            <button>Get Started ></button>
        </div>
    </div>
</section>

<section class="movies">
    <h2>Trending Now</h2>

    <div class="movie-row">
        <div class="movie">Movie 1</div>
        <div class="movie">Movie 2</div>
        <div class="movie">Movie 3</div>
        <div class="movie">Movie 4</div>
        <div class="movie">Movie 5</div>
    </div>
</section>

<section class="features">
    <h2>Why Choose Netflix?</h2>

    <div class="feature-box">
        Watch on Smart TVs, Playstation, Xbox and more.
    </div>

    <div class="feature-box">
        Download your shows to watch offline.
    </div>

    <div class="feature-box">
        Create profiles for kids and family.
    </div>
</section>

<footer>
    Netflix Clone Project | HTML & CSS Only
</footer>

</body>
</html>